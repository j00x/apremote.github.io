source "https://rubygems.org"

# Use the github-pages gem so local builds match the versions GitHub Pages
# uses when deploying via the `actions/jekyll-build-pages` workflow.
gem "github-pages", group: :jekyll_plugins

# Webrick is no longer bundled with Ruby 3.0+, but Jekyll's local server needs it.
gem "webrick", "~> 1.8"
